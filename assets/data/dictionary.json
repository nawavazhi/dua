    "allahumma_salli":      {"ar": "اللَّهُمَّ صَلِّ",                 "tr": "Allāhumma ṣalli",         "en": "O Allah, send blessings",                      "ml": "അല്ലാഹുവേ, അനുഗ്രഹം ചൊരിയേണമേ"},
    "ala_muhammadin":       {"ar": "عَلَى مُحَمَّدٍ",                  "tr": "'alā Muḥammadin",         "en": "upon Muhammad",                                "ml": "മുഹമ്മദ് നബിക്ക്"},
    "wa_ala_ali_muh":       {"ar": "وَعَلَى آلِ مُحَمَّدٍ",            "tr": "wa 'alā āli Muḥammadin",  "en": "and upon the family of Muhammad",              "ml": "മുഹമ്മദ് നബിയുടെ കുടുംബത്തിനും"},
    "kama_sallayta":        {"ar": "كَمَا صَلَّيْتَ",                  "tr": "kamā ṣallayta",           "en": "as You sent blessings",                        "ml": "നീ അനുഗ്രഹിച്ചതുപോലെ"},
    "ala_ibrahima":         {"ar": "عَلَى إِبْرَاهِيمَ",               "tr": "'alā Ibrāhīma",           "en": "upon Ibrahim",                                 "ml": "ഇബ്രാഹിം നബിക്ക്"},
    "wa_ala_ali_ib":        {"ar": "وَعَلَى آلِ إِبْرَاهِيمَ",         "tr": "wa 'alā āli Ibrāhīma",   "en": "and upon the family of Ibrahim",               "ml": "ഇബ്രാഹിം കുടുംബത്തിനും"},
    "innaka_hamid_majid":   {"ar": "إِنَّكَ حَمِيدٌ مَجِيدٌ",         "tr": "innaka Ḥamīdun Majīd",    "en": "Indeed You are Praiseworthy, Most Glorious",   "ml": "തീർച്ചയായും നീ സ്തുത്യർഹനും മഹത്വമുള്ളവനുമാണ്"},
    "allahumma_barik":      {"ar": "اللَّهُمَّ بَارِكْ",               "tr": "Allāhumma bārik",         "en": "O Allah, bless",                               "ml": "അല്ലാഹുവേ, നന്മ ചൊരിയേണമേ"},
    "kama_barakta":         {"ar": "كَمَا بَارَكْتَ",                  "tr": "kamā bārakta",            "en": "as You blessed",                               "ml": "നീ ചൊരിഞ്ഞതുപോലെ"},
    "allahumma_ighfir":     {"ar": "اللَّهُمَّ اغْفِرْ لِي",           "tr": "Allāhumma ighfir lī",     "en": "O Allah, forgive me",                          "ml": "അല്ലാഹുവേ, എനിക്ക് പൊറുത്തുതരേണമേ"},
    "ma_qaddamtu":          {"ar": "مَا قَدَّمْتُ",                    "tr": "mā qaddamtu",             "en": "what I have sent ahead (past sins)",           "ml": "ഞാൻ മുൻകൂട്ടി ചെയ്തവ"},
    "wa_ma_akhkhartu":      {"ar": "وَمَا أَخَّرْتُ",                  "tr": "wa mā akhkhartu",         "en": "and what I have left behind (future)",         "ml": "ഞാൻ പിന്നീടു ചെയ്യുന്നവ"},
    "wa_ma_asrartu":        {"ar": "وَمَا أَسْرَرْتُ",                 "tr": "wa mā asrartu",           "en": "and what I have hidden",                       "ml": "ഞാൻ രഹസ്യമായി ചെയ്തവ"},
    "wa_ma_a_lantu":        {"ar": "وَمَا أَعْلَنْتُ",                 "tr": "wa mā a'lantu",           "en": "and what I have declared openly",              "ml": "ഞാൻ പരസ്യമായി ചെയ്തവ"},
    "wa_ma_asraftu":        {"ar": "وَمَا أَسْرَفْتُ",                 "tr": "wa mā asraftu",           "en": "and where I have exceeded",                    "ml": "ഞാൻ അതിരുകടന്നവ"},
    "wa_ma_anta_a_lam":     {"ar": "وَمَا أَنْتَ أَعْلَمُ بِهِ مِنِّي","tr": "wa mā Anta a'lamu bihi minnī","en": "and what You know better than I do",       "ml": "നീ എന്നെക്കാൾ അറിയുന്നവ"},
    "antal_muqaddim":       {"ar": "أَنْتَ الْمُقَدِّمُ",              "tr": "Antal-Muqaddimu",         "en": "You are the One who brings forward",           "ml": "നീ മുന്തിക്കുന്നവൻ"},
    "wa_antal_muakhkhir":   {"ar": "وَأَنْتَ الْمُؤَخِّرُ",            "tr": "wa Antal-Mu'akhkhiru",    "en": "and You are the One who delays",               "ml": "നീ പിന്തിക്കുന്നവൻ"},
    "la_ilaha_illa_ant":    {"ar": "لَا إِلَهَ إِلَّا أَنْتَ",        "tr": "lā ilāha illā Anta",      "en": "there is no deity except You",                 "ml": "നിന്നെ അല്ലാതെ ആരാധ്യനില്ല"},
    "as_salamu_2":          {"ar": "السَّلَامُ",                        "tr": "As-salāmu",               "en": "Peace",                                        "ml": "സമാധാനം"},
    "alaykum":              {"ar": "عَلَيْكُمْ",                        "tr": "'alaykum",                "en": "be upon you (all)",                            "ml": "നിങ്ങളുടെ മേൽ ഉണ്ടാകട്ടെ"},
    "wa_rahmatu":           {"ar": "وَرَحْمَةُ",                        "tr": "wa raḥmatu",              "en": "and the mercy",                                "ml": "കാരുണ്യവും"},
    "qul":                  {"ar": "قُلْ",                             "tr": "Qul",                     "en": "Say",                                          "ml": "പറയുക"},
    "huwa_allahu":          {"ar": "هُوَ اللَّهُ",                      "tr": "huwal-lāhu",              "en": "He is Allah",                                  "ml": "അവൻ അല്ലാഹുവാകുന്നു"},
    "ahad":                 {"ar": "أَحَدٌ",                           "tr": "Aḥad",                    "en": "One / the Only",                               "ml": "ഏകനാണ്"},
    "allahus_samad":        {"ar": "اللَّهُ الصَّمَدُ",                 "tr": "Allāhuṣ-Ṣamad",           "en": "Allah, the Eternal Refuge",                    "ml": "അല്ലാഹു ആശ്രയമായിട്ടുള്ളവൻ"},
    "lam_yalid":            {"ar": "لَمْ يَلِدْ",                      "tr": "lam yalid",               "en": "He neither begets",                            "ml": "അവൻ ജന്മം നൽകിയില്ല"},
    "wa_lam_yulad":         {"ar": "وَلَمْ يُولَدْ",                   "tr": "wa lam yūlad",            "en": "nor was He begotten",                          "ml": "ജന്മം നൽകപ്പെട്ടിട്ടുമില്ല"},
    "lam_yakun_kufuwan":    {"ar": "وَلَمْ يَكُنْ لَهُ كُفُوًا أَحَدٌ","tr": "wa lam yakun lahu kufuwan aḥad","en": "and there is none equal to Him",          "ml": "അവന് തുല്യൻ ആരുമില്ല"},
    "a_udhu":               {"ar": "أَعُوذُ",                          "tr": "a'ūdhu",                  "en": "I seek refuge",                                "ml": "ഞാൻ അഭയം തേടുന്നു"},
    "bi_rabbil_falaq":      {"ar": "بِرَبِّ الْفَلَقِ",                "tr": "bi-rabbil-falaq",         "en": "in the Lord of the daybreak",                  "ml": "പുലരിയുടെ രക്ഷിതാവിനോട്"},
    "min_sharri_ma_khalaq": {"ar": "مِنْ شَرِّ مَا خَلَقَ",            "tr": "min sharri mā khalaqa",   "en": "from the evil of what He created",             "ml": "അവൻ സൃഷ്ടിച്ചതിന്റെ തിന്മ"},
    "wa_min_ghasiq":        {"ar": "وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ","tr": "wa min sharri ghāsiqin idhā waqab","en": "and from the evil of darkness when it settles","ml": "കൂരിരുട്ടിൽ നിന്നുള്ള തിന്മ"},
    "wa_min_naffathat":     {"ar": "وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ","tr": "wa min sharrin-naffāthāti fil-'uqad","en": "and from the evil of those who blow on knots","ml": "കെട്ടുകളിൽ ഊതുന്നവരുടെ"},
    "wa_min_hasid":         {"ar": "وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ","tr": "wa min sharri ḥāsidin idhā ḥasad","en": "and from the evil of an envier when he envies","ml": "അസൂയക്കാരന്റെ ദ്രോഹം"},
    "bi_rabbin_nas":        {"ar": "بِرَبِّ النَّاسِ",                  "tr": "bi-rabbin-nās",           "en": "in the Lord of mankind",                       "ml": "മനുഷ്യരുടെ രക്ഷിതാവിനോട്"},
    "malikin_nas":          {"ar": "مَلِكِ النَّاسِ",                   "tr": "malikin-nās",             "en": "the Sovereign of mankind",                     "ml": "മനുഷ്യരുടെ രാജാവ്"},
    "ilahin_nas":           {"ar": "إِلَهِ النَّاسِ",                   "tr": "ilāhin-nās",              "en": "the God of mankind",                           "ml": "മനുഷ്യരുടെ ആരാധ്യൻ"},
    "min_waswas_khannas":   {"ar": "مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ","tr": "min sharril-waswāsil-khannās","en": "from the evil of the retreating whisperer","ml": "ദുർബോധനക്കാരന്റെ തിന്മ"},
    "alladhi_yuwaswis":     {"ar": "الَّذِي يُوَسْوِسُ",               "tr": "alladhī yuwaswisu",       "en": "who whispers",                                 "ml": "ദുർബോധനം ചെയ്യുന്ന"},
    "fi_sudurin_nas":       {"ar": "فِي صُدُورِ النَّاسِ",              "tr": "fī ṣudūrin-nās",          "en": "into the hearts of mankind",                   "ml": "മനുഷ്യ ഹൃദയങ്ങളിൽ"},
    "minal_jinnati_wan_nas":{"ar": "مِنَ الْجِنَّةِ وَالنَّاسِ",        "tr": "minal-jinnati wan-nās",   "en": "from among the jinn and mankind",               "ml": "ജിന്നിൽ നിന്നും മനുഷ്യരിൽ നിന്നും"},
    "wal_asr":              {"ar": "وَالْعَصْرِ",                       "tr": "Wal-'aṣr",                "en": "By Time / the Epoch",                          "ml": "കാലം തന്നെ സത്യം"},
    "innal_insana":         {"ar": "إِنَّ الْإِنْسَانَ",               "tr": "innal-insāna",            "en": "Indeed mankind",                               "ml": "തീർച്ചയായും മനുഷ്യൻ"},
    "lafi_khusr":           {"ar": "لَفِي خُسْرٍ",                     "tr": "lafī khusr",              "en": "is in loss",                                   "ml": "നഷ്ടത്തിലാണ്"},
    "illal_ladhina":        {"ar": "إِلَّا الَّذِينَ آمَنُوا",          "tr": "illal-ladhīna āmanū",     "en": "except those who believe",                     "ml": "വിശ്വസിച്ചവർ ഒഴികെ"},
    "wa_amilus_salihat":    {"ar": "وَعَمِلُوا الصَّالِحَاتِ",         "tr": "wa 'amilus-ṣāliḥāt",      "en": "and do righteous deeds",                       "ml": "സൽകർമ്മങ്ങൾ ചെയ്തവർ"},
    "wa_tawasaw_haqq":      {"ar": "وَتَوَاصَوْا بِالْحَقِّ",          "tr": "wa tawāṣaw bil-ḥaqq",     "en": "and advise one another to truth",              "ml": "സത്യം കൊണ്ട് ഉപദേശിച്ചവർ"},
    "wa_tawasaw_sabr":      {"ar": "وَتَوَاصَوْا بِالصَّبْرِ",         "tr": "wa tawāṣaw biṣ-ṣabr",     "en": "and advise one another to patience",            "ml": "ക്ഷമ കൊണ്ട് ഉപദേശിച്ചവർ"},
    "inna_a_tayna":         {"ar": "إِنَّا أَعْطَيْنَاكَ",             "tr": "Innā a'ṭaynāka",          "en": "Indeed We have granted you",                   "ml": "തീർച്ചയായും നാം നിനക്ക് നൽകി"},
    "al_kawthar":           {"ar": "الْكَوْثَرَ",                       "tr": "al-kawthar",              "en": "Al-Kawthar (abundant good)",                   "ml": "കൗഥർ (ധാരാളം നന്മ)"},
    "fa_salli_li_rabb":     {"ar": "فَصَلِّ لِرَبِّكَ",                "tr": "fa-ṣalli li-rabbika",     "en": "So pray to your Lord",                         "ml": "നിന്റെ രക്ഷിതാവിനായി നമസ്കരിക്കുക"},
    "wanhar":               {"ar": "وَانْحَرْ",                         "tr": "wanḥar",                  "en": "and sacrifice",                                "ml": "ബലി അർപ്പിക്കുകയും"},
    "inna_shania_abtar":    {"ar": "إِنَّ شَانِئَكَ هُوَ الْأَبْتَرُ", "tr": "inna shāni'aka huwal-abtar","en": "Indeed your enemy is the one cut off",        "ml": "നിന്നോടു ദ്വേഷ്യം വെക്കുന്നവൻ ഭാവിയില്ലാത്തവൻ"}
  }
}
