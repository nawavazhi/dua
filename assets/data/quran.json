{
  "meta": {
    "file": "quran.json",
    "purpose": "Configuration for the Quran module. No Quran text is stored here — all text and audio is fetched live from external APIs. This file contains API URL templates, Surah metadata, and reader settings.",
    "version": "1.0.0",
    "developer": {
      "name": "Nawavazhi",
      "email": "nawavazhi@gmail.com",
      "github": "https://github.com/nawavazhi"
    }
  },
  "apis": {
    "quran_text": {
      "provider": "Quran.com API v4",
      "docs": "https://api.quran.com/documentation/v4",
      "base": "https://api.quran.com/api/v4",
      "word_by_word": "/verses/by_chapter/{surah}?language=ml&words=true&word_fields=text_uthmani,text_transliteration,translation_text",
      "verse_by_verse": "/verses/by_chapter/{surah}?language=ml&translations={translation_id}",
      "stability": "stable — v4 has been live since 2021",
      "note": "No API key required for basic word-by-word requests. Rate limit: 60 requests/minute."
    },
    "audio_word": {
      "provider": "QuranCDN (serves quran.com audio)",
      "template": "https://audio.qurancdn.com/wbw/{surah}/{verse}/{word_position}.mp3",
      "example": "https://audio.qurancdn.com/wbw/1/1/1.mp3",
      "note": "surah, verse, word_position are all 1-indexed integers. No padding needed.",
      "stability": "stable — CDN has served billions of requests since 2015"
    },
    "audio_verse": {
      "provider": "EveryAyah.com",
      "template": "https://everyayah.com/data/{reciter}/{surah_padded}{verse_padded}.mp3",
      "surah_padded": "3-digit zero-padded surah number (001–114)",
      "verse_padded": "3-digit zero-padded verse number (001–286)",
      "example": "https://everyayah.com/data/Alafasy_128kbps/001001.mp3",
      "stability": "stable — free, no API key, widely used"
    }
  },
  "reciters": [
    {"id": "Alafasy_128kbps",         "name": "Mishary Rashid Alafasy",   "quality": "128kbps", "default": true},
    {"id": "Abdul_Basit_Murattal_192", "name": "Abdul Basit (Murattal)",   "quality": "192kbps"},
    {"id": "Husary_128kbps",           "name": "Mahmoud Khalil Al-Husary", "quality": "128kbps"},
    {"id": "Minshawi_128kbps",         "name": "Mohamed Siddiq Al-Minshawi","quality": "128kbps"}
  ],
  "translation_ids": {
    "malayalam": 37,
    "english_saheeh": 131,
    "english_hilali": 85,
    "note": "These are quran.com translation IDs. Pass as translation_id in API requests."
  },
  "surahs": [
